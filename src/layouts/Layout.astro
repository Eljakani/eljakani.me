---
import { ClientRouter } from 'astro:transitions';
import '../styles/globals.css';
import { GoogleFontsOptimizer } from "astro-google-fonts-optimizer";
import { SEO } from "astro-seo";

interface Props {
  title?: string;
  description?: string;
  image?: string | ImageMetadata;
  ogType?: string;
  twitterCreator?: string;
  twitterCard?: "summary" | "summary_large_image" | "app" | "player";
  twitterSite?: string;
  siteName?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const defaultTitle = "Yassine El Jakani - Cyber Security Engineer";
const defaultDescription = "Cybersecurity engineer focused on DevSecOps, cloud security, penetration testing, secure web development, and security automation.";
const defaultImage = "https://eljakani.me/og-image.jpg";
const defaultOgType = "website";
const defaultTwitterCreator = "@eljakaniyassin";
const defaultTwitterCard = "summary_large_image";
const defaultTwitterSite = "@eljakaniyassin";
const defaultSiteName = "Yassine El Jakani";
const siteUrl = "https://eljakani.me";

const {
  title = defaultTitle,
  description = defaultDescription,
  image = defaultImage,
  ogType = defaultOgType,
  twitterCreator = defaultTwitterCreator,
  twitterCard = defaultTwitterCard,
  twitterSite = defaultTwitterSite,
  siteName = defaultSiteName,
  jsonLd
} = Astro.props;

const imagePath = typeof image === 'string' ? image : image.src;
const seoImage = new URL(imagePath, siteUrl).toString();
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const structuredData = jsonLd ?? [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Yassine El Jakani",
    url: siteUrl,
    image: defaultImage,
    jobTitle: "Cybersecurity Engineer",
    email: "mailto:eljakaniyassin@gmail.com",
    sameAs: [
      "https://github.com/Eljakani",
      "https://linkedin.com/in/eljakaniyassine",
      "https://x.com/eljakaniyassin"
    ],
    knowsAbout: [
      "Cybersecurity",
      "DevSecOps",
      "Cloud Security",
      "Penetration Testing",
      "Secure Web Development",
      "Security Automation"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: defaultSiteName,
    url: siteUrl,
    description: defaultDescription,
    inLanguage: "en"
  }
];
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#020817" />
  <SEO
      title={title}
      description={description}
      canonical={canonicalUrl}
      openGraph={{
        basic: {
          title: title,
          type: ogType,
          image: seoImage,
          url: canonicalUrl,
        },
        image: {
          url: seoImage,
          alt: title,
          width: 1200,
          height: 630,
          type: "image/jpeg",
        },
        optional: {
          siteName: siteName,
          description: description,
        },
      }}
      twitter={{
        card: twitterCard,
        creator: twitterCreator,
        site: twitterSite,
        title: title,
        image: seoImage,
        imageAlt: title,
        description: description,
      }}
      extend={{
        link: [
          { rel: "icon", href: "/favicon.svg" },
          { rel: "sitemap", href: "/sitemap-index.xml" },
          { rel: "alternate", type: "application/rss+xml", href: "/rss.xml", title: "Yassine El Jakani Blog RSS" },
          { rel: "alternate", type: "text/plain", href: "/llms.txt", title: "LLM reference" }
        ],
        meta: [
          { name: "generator", content: Astro.generator },
        ],
      }}
  />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <ClientRouter />
  <GoogleFontsOptimizer url="https://fonts.googleapis.com/css2?family=Red+Hat+Display:ital,wght@0,300..900;1,300..900&family=Ubuntu:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&display=swap" />
  <script is:inline>
    function getThemePreference() {
      if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
        return localStorage.getItem('theme');
      }
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }

    function setTheme(theme) {
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
      window.localStorage.setItem('theme', theme);
    }

    setTheme(getThemePreference());

    document.addEventListener('astro:after-swap', () => {
      setTheme(getThemePreference());
    });
  </script>
</head>
<body class="min-h-screen bg-background font-sans antialiased">
<div class="relative flex min-h-screen flex-col container mx-auto px-4 max-w-5xl">
  <div class="flex-1">
    <slot />
  </div>
</div>
</body>
</html>
