---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer';
import PostCard from '@/components/blog/PostCard.astro';
import { calculateReadingTime, generateArticleSchema, getRelatedPosts, normalizeTag, sortPostsByDate } from '@/utils/blog';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

type Props = CollectionEntry<'blog'>;
type Heading = { depth: number; slug: string; text: string };

const post = Astro.props as Props;
const { Content, headings } = await render(post);
const visibleHeadings = (headings as Heading[]).filter((heading) => heading.depth <= 3);
const readingTime = calculateReadingTime(post.body ?? '');
const allPosts = sortPostsByDate(await getCollection('blog'));
const relatedPosts = getRelatedPosts(post, allPosts, 3);
const articleUrl = `https://eljakani.me/blog/${post.id}`;
const jsonLd = generateArticleSchema(post, articleUrl);
const image = post.data.image ?? '/og-image.jpg';
---

<Layout title={`${post.data.title} | Yassine El Jakani`} description={post.data.description} image={image} ogType="article" jsonLd={jsonLd}>
  <div id="reading-progress" class="fixed left-0 top-0 z-[70] h-1 bg-primary transition-[width]" style="width: 0%"></div>

  <div class="container mx-auto px-4">
    <Header />

    <article class="py-10">
      <header class="mx-auto max-w-4xl">
        <nav class="mb-8 text-sm text-foreground/60" aria-label="Breadcrumb">
          <a href="/" class="hover:text-primary">Home</a>
          <span class="mx-2">/</span>
          <a href="/blog" class="hover:text-primary">Blog</a>
        </nav>

        <div class="mb-6 flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <a href={`/blog/tags/${normalizeTag(tag)}`} class="rounded-full border bg-background px-3 py-1 text-xs text-foreground/70 transition-colors hover:bg-primary hover:text-primary-foreground">
              {tag}
            </a>
          ))}
        </div>

        <h1 class="text-4xl font-bold leading-tight text-foreground md:text-6xl">{post.data.title}</h1>
        <p class="mt-5 text-xl leading-relaxed text-foreground/75">{post.data.description}</p>

        <div class="mt-6 flex flex-wrap items-center gap-3 text-sm text-foreground/60">
          <span>{post.data.author}</span>
          <span>•</span>
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          </time>
          <span>•</span>
          <span>{readingTime} min read</span>
        </div>
      </header>

      <div class="mx-auto mt-10 max-w-5xl overflow-hidden rounded-3xl border">
        <img src={image} alt={post.data.title} class="aspect-[16/9] w-full object-cover" loading="eager" />
      </div>

      <div class="mx-auto mt-12 grid max-w-6xl gap-10 lg:grid-cols-[minmax(0,1fr)_16rem]">
        <div class="article-content min-w-0">
          <Content />
        </div>

        {visibleHeadings.length > 0 && (
          <aside class="hidden lg:block">
            <div class="sticky top-24 rounded-2xl border bg-muted/20 p-5">
              <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-foreground/60">Contents</h2>
              <nav class="space-y-2">
                {visibleHeadings.map((heading) => (
                  <a href={`#${heading.slug}`} class={`block text-sm transition-colors hover:text-primary ${heading.depth === 3 ? 'pl-4 text-foreground/55' : 'text-foreground/75'}`}>
                    {heading.text}
                  </a>
                ))}
              </nav>
            </div>
          </aside>
        )}
      </div>
    </article>

    {relatedPosts.length > 0 && (
      <section class="py-16">
        <h2 class="mb-8 text-3xl font-bold text-foreground">Continue Reading</h2>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {relatedPosts.map((relatedPost) => (
            <PostCard post={relatedPost} />
          ))}
        </div>
      </section>
    )}

    <Footer client:load />
  </div>

  <style>
    .article-content {
      @apply mx-auto max-w-3xl text-foreground/85;
    }
    .article-content :global(p) {
      @apply mb-6 text-lg leading-8 text-foreground/80;
    }
    .article-content :global(p:first-of-type) {
      @apply text-xl leading-9 text-foreground/90;
    }
    .article-content :global(h2) {
      @apply mb-5 mt-12 text-3xl font-bold text-foreground font-alt;
    }
    .article-content :global(h3) {
      @apply mb-4 mt-10 text-2xl font-semibold text-foreground font-alt;
    }
    .article-content :global(ul),
    .article-content :global(ol) {
      @apply mb-8 ml-6 space-y-3 text-lg leading-8;
    }
    .article-content :global(ul) {
      @apply list-disc;
    }
    .article-content :global(ol) {
      @apply list-decimal;
    }
    .article-content :global(a) {
      @apply text-primary underline underline-offset-4;
    }
    .article-content :global(blockquote) {
      @apply my-8 border-l-4 border-primary pl-5 text-xl italic text-foreground/75;
    }
    .article-content :global(code) {
      @apply rounded bg-muted px-1.5 py-0.5 text-sm;
    }
    .article-content :global(pre) {
      @apply mb-8 overflow-x-auto rounded-2xl border bg-muted p-5;
    }
  </style>

  <script>
    document.addEventListener('astro:page-load', () => {
      const progress = document.getElementById('reading-progress');
      const updateProgress = () => {
        if (!progress) return;
        const scrollTop = window.scrollY;
        const height = document.documentElement.scrollHeight - window.innerHeight;
        const width = height > 0 ? (scrollTop / height) * 100 : 0;
        progress.style.width = `${Math.min(100, Math.max(0, width))}%`;
      };
      updateProgress();
      window.addEventListener('scroll', updateProgress, { passive: true });
    });
  </script>
</Layout>
