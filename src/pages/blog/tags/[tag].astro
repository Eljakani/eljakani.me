---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer';
import PostCard from '@/components/blog/PostCard.astro';
import { normalizeTag, sortPostsByDate } from '@/utils/blog';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = Array.from(new Set(posts.flatMap((post) => post.data.tags)));

  return tags.map((tag) => ({
    params: { tag: normalizeTag(tag) },
    props: { tag },
  }));
}

const originalTag = Astro.props.tag as string;
const normalizedTag = normalizeTag(originalTag);
const posts = sortPostsByDate(await getCollection('blog')).filter((post) =>
  post.data.tags.some((tag) => normalizeTag(tag) === normalizedTag)
);
const title = `${originalTag} Articles | Yassine El Jakani`;
const description = `Articles and notes tagged ${originalTag} from Yassine El Jakani.`;
---

<Layout title={title} description={description}>
  <div class="container mx-auto px-4">
    <Header />
    <section class="py-16">
      <a href="/blog" class="text-sm text-primary hover:underline">Back to all posts</a>
      <h1 class="mt-4 text-4xl font-bold text-foreground">{originalTag}</h1>
      <p class="mt-3 text-foreground/70">{posts.length} {posts.length === 1 ? 'article' : 'articles'}</p>

      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    </section>
    <Footer client:load />
  </div>
</Layout>
