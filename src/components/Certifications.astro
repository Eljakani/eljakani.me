---
import { Icon } from 'astro-icon/components';

const certifications = [
    {
        title: "KCNA: Kubernetes and Cloud Native Associate",
        issuer: "The Linux Foundation",
        logo: "/certifications/linux-foundation-logo.jpg",
        issued: "Apr 2026",
        expires: "Apr 2028",
        credentialUrl: "https://www.credly.com/badges/90c3810a-bdf5-4e94-b1dd-b91f0bb01405/linked_in_profile",
        summary: "Vendor-neutral cloud native certification covering Kubernetes fundamentals, container orchestration, and CNCF ecosystem concepts.",
        tags: ["Kubernetes", "Docker", "Cloud Native", "CNCF"],
    },
    {
        title: "Kubernetes and Cloud Native Essentials",
        issuer: "The Linux Foundation",
        logo: "/certifications/linux-foundation-logo.jpg",
        issued: "Apr 2026",
        credentialId: "5857ed39-8afc-4159-a529-8faa0e987a46",
        credentialUrl: "https://www.credly.com/badges/5857ed39-8afc-4159-a529-8faa0e987a46",
        summary: "Practical foundation in Kubernetes, containers, microservices, and cloud native application delivery.",
        tags: ["Kubernetes", "Docker", "Containers", "Cloud Native"],
    },
    {
        title: "Compétences pratiques sur les PKI et Autorités de Certification",
        issuer: "Cours CyberPKI.fr",
        logo: "/certifications/cyberpki-logo.jpg",
        issued: "Apr 2026",
        credentialId: "69e531506d6f6823a21cb61f",
        credentialUrl: "https://badges.parchment.eu/public/assertions/qdsCVDTQSxWLQ8_NdnbXzw",
        summary: "Hands-on PKI and certificate authority training focused on public key infrastructure operations and trust chains.",
        tags: ["PKI", "Certificate Authority", "Cryptography"],
    },
    {
        title: "Oracle Cloud Infrastructure 2025 Certified Foundations Associate",
        issuer: "Oracle",
        logo: "/certifications/oracle-logo.jpg",
        issued: "Apr 2025",
        expires: "Apr 2027",
        credentialId: "C0CEB37187AA2848E6C0CE0882C1682EEFF8A4D51C1FEA527C7B17A0BB2FCD55",
        credentialUrl: "https://catalog-education.oracle.com/ords/certview/sharebadge?id=C0CEB37187AA2848E6C0CE0882C1682EEFF8A4D51C1FEA527C7B17A0BB2FCD55",
        summary: "Foundational Oracle Cloud Infrastructure knowledge across core services, cloud architecture, security, and governance.",
        tags: ["Cloud Computing", "OCI", "Cloud Security"],
    },
    {
        title: "AWS Educate Getting Started with Serverless",
        issuer: "Amazon Web Services (AWS)",
        logo: "/certifications/aws-logo.jpg",
        issued: "Sep 2024",
        credentialId: "2926f3e2-bd29-465c-9140-be9769ade894",
        credentialUrl: "https://www.credly.com/earner/earned/badge/2926f3e2-bd29-465c-9140-be9769ade894",
        summary: "Introductory AWS serverless badge covering event-driven services and managed compute patterns.",
        tags: ["AWS", "Serverless", "Cloud Computing"],
    },
    {
        title: "ISO/IEC 27001 Information Security Associate™",
        issuer: "SkillFront",
        logo: "/certifications/skillfront-logo.jpg",
        issued: "Apr 2024",
        credentialId: "18683482289501",
        credentialUrl: "https://www.skillfront.com/Badges/18683482289501",
        summary: "Foundational information security management knowledge aligned with ISO/IEC 27001 practices.",
        tags: ["ISO 27001", "Information Security", "Risk Management"],
    },
];
---

<section id="certifications" class="py-16">
    <div class="mb-10 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
            <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-primary/70">Credentials</p>
            <h3 class="text-4xl font-bold text-foreground">Certifications & Badges</h3>
        </div>
        <div class="flex gap-3 text-sm text-foreground/70">
            <span class="rounded-full border bg-background px-3 py-1.5">{certifications.length} credentials</span>
            <span class="rounded-full border bg-background px-3 py-1.5">Cloud, Security, DevOps</span>
        </div>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {certifications.map((cert) => (
            <article class="group flex min-h-[23rem] flex-col rounded-2xl border bg-gradient-to-br from-background to-muted/25 p-5 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/30 hover:shadow-xl">
                <div class="flex items-start justify-between gap-4">
                    <div class="flex items-center gap-4">
                        <div class="flex h-16 w-16 shrink-0 items-center justify-center overflow-hidden rounded-2xl border bg-white p-3 shadow-sm">
                            <img src={cert.logo} alt={`${cert.issuer} logo`} class="h-full w-full object-contain" loading="lazy" />
                        </div>
                        <div class="min-w-0 flex-1">
                            <p class="text-sm font-medium text-primary/80">{cert.issuer}</p>
                            <div class="mt-2 inline-flex items-center gap-1.5 rounded-full border border-primary/20 bg-primary/10 px-2.5 py-1 text-xs font-medium text-primary">
                                <Icon name="lucide:badge-check" class="h-3.5 w-3.5" />
                                Credential
                            </div>
                        </div>
                    </div>
                    <a
                        href={cert.credentialUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-muted text-foreground/70 transition-colors group-hover:bg-primary group-hover:text-primary-foreground"
                        aria-label={`View credential for ${cert.title}`}
                    >
                        <Icon name="lucide:external-link" class="h-4 w-4" />
                    </a>
                </div>

                <h4 class="mt-5 text-xl font-semibold leading-tight text-foreground font-alt">
                    {cert.title}
                </h4>

                <div class="mt-4 flex flex-wrap gap-x-4 gap-y-2 text-xs text-foreground/60">
                    <span class="flex items-center gap-1.5">
                        <Icon name="lucide:calendar" class="h-3.5 w-3.5 text-primary/70" />
                        Issued {cert.issued}
                    </span>
                    {cert.expires && (
                        <span class="flex items-center gap-1.5">
                            <Icon name="lucide:timer" class="h-3.5 w-3.5 text-primary/70" />
                            Until {cert.expires}
                        </span>
                    )}
                </div>

                <p class="mt-4 flex-1 text-sm leading-relaxed text-foreground/75">
                    {cert.summary}
                </p>

                {cert.credentialId && (
                    <p class="mt-4 truncate rounded-lg bg-muted/50 px-3 py-2 text-xs text-foreground/55" title={cert.credentialId}>
                        <span class="font-semibold text-foreground/70">ID:</span> {cert.credentialId}
                    </p>
                )}

                <div class="mt-4 flex flex-wrap gap-2">
                    {cert.tags.map((tag) => (
                        <span class="rounded-full bg-muted px-2.5 py-1 text-xs text-foreground/70">
                            {tag}
                        </span>
                    ))}
                </div>
            </article>
        ))}
    </div>
</section>
